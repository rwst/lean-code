namespace BL

open PadicInt MeasureTheory Filter Topology

/-- The **parity** of a 2-adic integer: `0` if even, `1` if odd Рђћ the value of `x mod 2` under the
residue map `РёцРѓѓ Рєњ ZMod 2`. The 2-adic analogue of `CC.X` on `РёЋ`. -/
@[category API, AMS 11 37, ref "BL96"]
noncomputable def parity (x : Рёц_[2]) : РёЋ := (PadicInt.toZMod x).val

/-- The residue of the (cast) parity equals the residue of `x`: `toZMod РєЉ(parity x) = toZMod x`. -/
@[category API, AMS 11 37, ref "BL96"]
theorem toZMod_natCast_parity (x : Рёц_[2]) :
    PadicInt.toZMod ((parity x : Рёц_[2])) = PadicInt.toZMod x := by
  unfold parity; rw [map_natCast, ZMod.natCast_val, ZMod.cast_id]

/-- On `РёЋ Ріѓ РёцРѓѓ` the 2-adic parity is the Collatz parity `CC.X`: `parity РєЉn = X n`
(`= n mod 2`). Base case of the parity-vector bridge to `CC.Parity`. -/
@[category API, AMS 11 37, ref "BL96"]
theorem parity_natCast (n : РёЋ) : parity (n : Рёц_[2]) = CC.X n := by
  unfold parity; rw [map_natCast, ZMod.val_natCast, CC.X_eq_mod]

/-- The unique **half** of an even 2-adic integer (`РёцРѓѓ` is a domain, so `2┬иy = x` has at most one
solution). Used to define both the 3x+1 map and the shift as "even numerator, halved". -/
@[category API, AMS 11 37, ref "BL96"]
noncomputable def half {x : Рёц_[2]} (h : (2 : Рёц_[2]) РѕБ x) : Рёц_[2] := h.choose

/-- Defining property of `half`: `2 ┬и half h = x`. -/
@[category API, AMS 11 37, ref "BL96"]
theorem two_mul_half {x : Рёц_[2]} (h : (2 : Рёц_[2]) РѕБ x) : 2 * half h = x := h.choose_spec.symm

/-! ### The 3x+1 map on `РёцРѓѓ` (extension of (1.1)) -/

/-- The **numerator** `x ┬и 3^{parity x} + parity x` of the 3x+1 map (cf. the `РёЋ` form
`n┬и3^{X n} + X n = 2┬иT n`). It is always even, so the 3x+1 map `TРѓѓ` is `numer / 2`. -/
@[category API, AMS 11 37, ref "BL96"]
noncomputable def numer (x : Рёц_[2]) : Рёц_[2] := x * 3 ^ parity x + (parity x : Рёц_[2])

/-- The numerator `x┬и3^{parity x} + parity x` is even in `РёцРѓѓ`: modulo `2` it is `x + x РЅА 0`, since
`3 РЅА 1`. Hence `TРѓѓ` is well defined. -/
@[category API, AMS 11 37, ref "BL96"]
theorem even_numer (x : Рёц_[2]) : (2 : Рёц_[2]) РѕБ numer x := by
  have h3 : PadicInt.toZMod (3 : Рёц_[2]) = 1 := by
    have : (3 : Рёц_[2]) = ((3 : РёЋ) : Рёц_[2]) := by norm_num
    rw [this, map_natCast]; decide
  have hz : PadicInt.toZMod (numer x) = 0 := by
    unfold numer
    rw [map_add, map_mul, map_pow, h3, one_pow, mul_one, toZMod_natCast_parity]
    exact CharTwo.add_self_eq_zero _
  have hk : numer x Рѕѕ RingHom.ker (PadicInt.toZMod (p := 2)) := hz
  rw [PadicInt.ker_toZMod, PadicInt.maximalIdeal_eq_span_p, Ideal.mem_span_singleton] at hk
  simpa using hk

/-- The **3x+1 function on the 2-adic integers** `РёцРѓѓ`, the extension of `(1.1)`/`CC.T`
to `Рёц_[2]`: `TРѓѓ x` is the (unique) half of the even numerator `numer x`. -/
@[category API, AMS 11 37, ref "BL96"]
noncomputable def TРѓѓ (x : Рёц_[2]) : Рёц_[2] := half (even_numer x)

/-- Defining identity of `TРѓѓ`: `2 ┬и TРѓѓ x = x ┬и 3^{parity x} + parity x`. On odd `x` this is
`2┬иTРѓѓ x = 3x+1`, on even `x` it is `2┬иTРѓѓ x = x`. -/
@[category API, AMS 11 37, ref "BL96"]
theorem two_mul_TРѓѓ (x : Рёц_[2]) : 2 * TРѓѓ x = numer x := two_mul_half (even_numer x)

/-- `TРѓѓ` extends the integer map: on `РёЋ Ріѓ РёцРѓѓ` it agrees with `CC.T`. So `(1.1)` really
is the restriction of `TРѓѓ` to the integers. -/
@[category API, AMS 11 37, ref "BL96"]
theorem TРѓѓ_natCast (n : РёЋ) : TРѓѓ (n : Рёц_[2]) = (CC.T n : Рёц_[2]) := by
  have hcancel : (2 : Рёц_[2]) * TРѓѓ (n : Рёц_[2]) = 2 * (CC.T n : Рёц_[2]) := by
    rw [two_mul_TРѓѓ]
    unfold numer
    rw [parity_natCast]
    have hexp := CC.T_expand n
    have hcast : 2 * ((CC.T n : РёЋ) : Рёц_[2])
        = ((3 ^ CC.X n * n + CC.X n : РёЋ) : Рёц_[2]) := by
      rw [Рєљ hexp]; push_cast; ring
    rw [hcast]; push_cast; ring
  exact mul_left_cancelРѓђ (by norm_num) hcancel

/-! ### The 2-adic shift map (1.2) -/

/-- The **numerator** `x - parity x` of the shift map: even (`x РЅА parity x mod 2`), so `S` is
`(x - parity x)/2` Рђћ i.e. `x/2` if even, `(x-1)/2` if odd. -/
@[category API, AMS 11 37, ref "BL96"]
noncomputable def shiftNumer (x : Рёц_[2]) : Рёц_[2] := x - (parity x : Рёц_[2])

/-- The shift numerator `x - parity x` is even in `РёцРѓѓ` (`x РЅА parity x mod 2`). -/
@[category API, AMS 11 37, ref "BL96"]
theorem even_shiftNumer (x : Рёц_[2]) : (2 : Рёц_[2]) РѕБ shiftNumer x := by
  have hz : PadicInt.toZMod (shiftNumer x) = 0 := by
    unfold shiftNumer
    rw [map_sub, toZMod_natCast_parity, sub_self]
  have hk : shiftNumer x Рѕѕ RingHom.ker (PadicInt.toZMod (p := 2)) := hz
  rw [PadicInt.ker_toZMod, PadicInt.maximalIdeal_eq_span_p, Ideal.mem_span_singleton] at hk
  simpa using hk

/-- The **2-adic shift map** `(1.2)` `S : РёцРѓѓ Рєњ РёцРѓѓ`, `S(x) = (x-1)/2` for odd `x` and `x/2` for even
`x`: the (unique) half of the even numerator `x - parity x`. It deletes the lowest binary digit. -/
@[category API, AMS 11 37, ref "BL96"]
noncomputable def S (x : Рёц_[2]) : Рёц_[2] := half (even_shiftNumer x)

/-- Defining identity of the shift: `2 ┬и S x = x - parity x`. -/
@[category API, AMS 11 37, ref "BL96"]
theorem two_mul_S (x : Рёц_[2]) : 2 * S x = x - (parity x : Рёц_[2]) := two_mul_half (even_shiftNumer x)

/-- The shift deletes the lowest binary digit: `x = parity x + 2 ┬и S x`. With `x = РѕЉ bрхб2РЂ▒` this says
`S x = РѕЉ bрхбРѓіРѓЂ2РЂ▒` (the lowest digit `bРѓђ = parity x` is dropped and the rest shift down). -/
@[category API, AMS 11 37, ref "BL96"]
theorem parity_add_two_mul_S (x : Рёц_[2]) : (parity x : Рёц_[2]) + 2 * S x = x := by
  rw [two_mul_S]; ring

/-- On `РёЋ Ріѓ РёцРѓѓ` the shift is integer division by `2`: `S РєЉn = РєЉРїіn/2РїІ`. -/
@[category API, AMS 11 37, ref "BL96"]
theorem S_natCast (n : РёЋ) : S (n : Рёц_[2]) = ((n / 2 : РёЋ) : Рёц_[2]) := by
  have hpar : parity (n : Рёц_[2]) = n % 2 := by unfold parity; rw [map_natCast, ZMod.val_natCast]
  have hcancel : (2 : Рёц_[2]) * S (n : Рёц_[2]) = 2 * ((n / 2 : РёЋ) : Рёц_[2]) := by
    rw [two_mul_S, hpar, Рєљ Nat.cast_sub (Nat.mod_le n 2)]
    have h2 : n - n % 2 = 2 * (n / 2) := by omega
    rw [h2]; push_cast; ring
  exact mul_left_cancelРѓђ (by norm_num) hcancel

/-! ### Bridges to the Collatz parity vectors (`CC.Parity`)

The inverse conjugacy map `╬дРЂ╗┬╣`/`QРѕъ` sends `x` to the parity sequence `k Рєд parity (TРѓѓрхЈ x)`. On `РёЋ` these
digits are exactly `CC.Parity`'s finite parity vectors of the Collatz orbit. -/

/-- Iterating `TРѓѓ` on `РёЋ Ріѓ РёцРѓѓ` is iterating the integer map: `TРѓѓрхЈ РєЉn = РєЉ(TрхЈ n)`. -/
@[category API, AMS 11 37, ref "BL96"]
theorem TРѓѓ_iterate_natCast (k n : РёЋ) :
    (TРѓѓ^[k]) (n : Рёц_[2]) = ((CC.T_iter k n : РёЋ) : Рёц_[2]) := by
  induction k with
  | zero => rfl
  | succ k ih => rw [Function.iterate_succ', Function.comp_apply, ih, TРѓѓ_natCast]; rfl

/-- **Parity-vector bridge.** The `k`-th parity digit of the `TРѓѓ`-orbit of `РєЉn` is the `k`-th entry
of the Collatz parity vector: `parity (TРѓѓрхЈ РєЉn) = X (TрхЈ n)`. This is `QРѕъ`/`╬дРЂ╗┬╣` (at digit `k`) on `РёЋ`. -/
@[category API, AMS 11 37, ref "BL96"]
theorem parity_TРѓѓ_iterate_natCast (k n : РёЋ) :
    parity (TРѓѓ^[k] (n : Рёц_[2])) = CC.X (CC.T_iter k n) := by
  rw [TРѓѓ_iterate_natCast, parity_natCast]

/-- The 2-adic parity digits of the `TРѓѓ`-orbit are the `РёЋ`-valued parity vector `CC.Parity.E_vec`:
`parity (TРѓѓРЂ▒ РєЉn) = E_vec k n i`. -/
@[category API, AMS 11 37, ref "BL96"]
theorem parity_TРѓѓ_iterate_eq_E_vec (k n : РёЋ) (i : Fin k) :
    parity (TРѓѓ^[i.val] (n : Рёц_[2])) = CC.E_vec k n i := by
  rw [parity_TРѓѓ_iterate_natCast, CC.E_vec_apply]

/-- The 2-adic parity digits are the `Bool` parity word `CC.Parity.V` (the literal `QРѕъ` truncation):
its `i`-th entry is `decide (parity (TРѓѓРЂ▒ РєЉn) = 1)`. -/
@[category API, AMS 11 37, ref "BL96"]
theorem getElem_V_eq_parity (j n : РёЋ) (i : Fin j) :
    (CC.V j n).get РЪеi.val, by simpРЪЕ = decide (parity (TРѓѓ^[i.val] (n : Рёц_[2])) = 1) := by
  rw [CC.V_get, parity_TРѓѓ_iterate_natCast]

/-- The number of odd Collatz iterates is the sum of the 2-adic parity digits of the `TРѓѓ`-orbit:
`num_odd_steps k n = РѕЉ_{i<k} parity (TРѓѓРЂ▒ РєЉn)` (the weight `q` of the parity vector). -/
@[category API, AMS 11 37, ref "BL96"]
theorem num_odd_steps_eq_sum_parity (k n : РёЋ) :
    CC.num_odd_steps k n = РѕЉ i Рѕѕ Finset.range k, parity (TРѓѓ^[i] (n : Рёц_[2])) := by
  rw [CC.num_odd_steps]
  exact Finset.sum_congr rfl (fun i _ => (parity_TРѓѓ_iterate_natCast i n).symm)

/-! ### Strong mixing and Bernoulli systems (general)

General measure-theoretic notions (not specific to the 3x+1 map), used to state Рђћ and partly to
derive Рђћ the cited ergodic-theoretic facts about `TРѓѓ` below. -/

/-- A measure-preserving system `(f, ╬╝)` is **strongly mixing** if `╬╝ (fРЂ╗РЂ┐ A РѕЕ B) Рєњ ╬╝ A ┬и ╬╝ B` for
all measurable `A, B` (this bundles measure preservation). -/
@[category API, AMS 37 28, ref "BL96"]
def StronglyMixing {╬▒ : Type*} [MeasurableSpace ╬▒] (f : ╬▒ Рєњ ╬▒) (╬╝ : Measure ╬▒) : Prop :=
  MeasurePreserving f ╬╝ ╬╝ РѕД Рѕђ A B, MeasurableSet A Рєњ MeasurableSet B Рєњ
    Tendsto (fun n => ╬╝ (f^[n] РЂ╗┬╣' A РѕЕ B)) atTop (­ЮЊЮ (╬╝ A * ╬╝ B))

/-- **Strong mixing implies ergodicity.** For an invariant set `s` (`fРЂ╗┬╣ s = s`), mixing with
`A = B = s` gives `╬╝ s = ╬╝ s ┬и ╬╝ s`, forcing `╬╝ s Рѕѕ {0, 1}`. A genuine (sorry-free) proof. -/
@[category API, AMS 37 28, ref "BL96"]
theorem StronglyMixing.ergodic {╬▒ : Type*} [MeasurableSpace ╬▒] {f : ╬▒ Рєњ ╬▒} {╬╝ : Measure ╬▒}
    [IsProbabilityMeasure ╬╝] (h : StronglyMixing f ╬╝) : Ergodic f ╬╝ := by
  refine РЪеh.1, РЪеfun s hs hinv => ?_РЪЕРЪЕ
  have hiter : Рѕђ n, f^[n] РЂ╗┬╣' s = s := by
    intro n
    induction n with
    | zero => simp
    | succ k ih => rw [Function.iterate_succ', Set.preimage_comp, hinv, ih]
  have hmix := h.2 s s hs hs
  have hconst : (fun n => ╬╝ (f^[n] РЂ╗┬╣' s РѕЕ s)) = fun _ => ╬╝ s := by
    funext n; rw [hiter n, Set.inter_self]
  rw [hconst] at hmix
  have huniq : ╬╝ s = ╬╝ s * ╬╝ s := tendsto_nhds_unique tendsto_const_nhds hmix
  have hdich : ╬╝ s = 0 Рѕе ╬╝ s = 1 := by
    rcases eq_or_ne (╬╝ s) 0 with h0 | h0
    ┬и exact Or.inl h0
    ┬и exact Or.inr ((ENNReal.mul_eq_left h0 (measure_ne_top ╬╝ s)).mp huniq.symm)
  rw [eventuallyConst_set]
  rcases hdich with h0 | hs1
  ┬и exact Or.inr (by rw [ae_iff]; simpa using h0)
  ┬и refine Or.inl (by rw [ae_iff, show {a | a РѕЅ s} = sрХю from rfl,
      measure_compl hs (measure_ne_top ╬╝ s), measure_univ, hs1, tsub_self])

/-- The one-sided shift on `Bool`-sequences (drop the `0`th coordinate). -/
@[category API, AMS 37 28, ref "BL96"]
def seqShift (x : РёЋ Рєњ Bool) : РёЋ Рєњ Bool := fun n => x (n + 1)

/-- The uniform `(┬й,┬й)` measure on `Bool`. -/
@[category API, AMS 37 28, ref "BL96"]
noncomputable def uniformBool : Measure Bool :=
  (1 / 2 : ENNReal) Рђб Measure.dirac true + (1 / 2 : ENNReal) Рђб Measure.dirac false

/-- The one-sided **Bernoulli `(┬й,┬й)` measure** on `РёЋ Рєњ Bool`: i.i.d. uniform binary digits. -/
@[category API, AMS 37 28, ref "BL96"]
noncomputable def bernoulliSeqMeasure : Measure (РёЋ Рєњ Bool) :=
  Measure.infinitePi (fun _ => uniformBool)

/-- A measure-preserving system `(f, ╬╝)` is **Bernoulli** if it is isomorphic Рђћ via a
measure-preserving measurable equivalence `e` intertwining the dynamics (`Semiconj e f seqShift`) Рђћ
to the one-sided Bernoulli `(┬й,┬й)` shift `(seqShift, bernoulliSeqMeasure)` on `РёЋ Рєњ Bool`. -/
@[category API, AMS 37 28, ref "BL96"]
def IsBernoulli {╬▒ : Type*} [MeasurableSpace ╬▒] (f : ╬▒ Рєњ ╬▒) (╬╝ : Measure ╬▒) : Prop :=
  РѕЃ e : ╬▒ РЅЃрхљ (РёЋ Рєњ Bool),
    MeasurePreserving (РЄЉe) ╬╝ bernoulliSeqMeasure РѕД Function.Semiconj (РЄЉe) f seqShift

/-! ### Ergodic theory and conjugacy of `TРѓѓ` (cited) -/

/-- **(BernsteinРђЊLagarias, ┬Д1; cited.)** The 3x+1 map `TРѓѓ` is **strongly mixing** on `РёцРѓѓ` for the
2-adic measure (normalised additive Haar on the Borel `¤Ѓ`-algebra). This is the paper's reference
[8] = [Lag85]; recorded as a cited `axiom`, from which measure preservation and ergodicity are
derived below. -/
@[category research solved, AMS 37 28, ref "BL96" "Lag85", group "bl_2adic_dynamics"]
axiom TРѓѓ_stronglyMixing [MeasurableSpace Рёц_[2]] [BorelSpace Рёц_[2]]
    (╬╝ : Measure Рёц_[2]) [╬╝.IsAddHaarMeasure] [IsProbabilityMeasure ╬╝] :
    StronglyMixing TРѓѓ ╬╝

/-- `TРѓѓ` is **measure-preserving** on `РёцРѓѓ` for the 2-adic measure Рђћ the first component of strong
mixing (`TРѓѓ_stronglyMixing`). -/
@[category research solved, AMS 37 28, ref "BL96" "Lag85", group "bl_2adic_dynamics"]
theorem TРѓѓ_measurePreserving [MeasurableSpace Рёц_[2]] [BorelSpace Рёц_[2]]
    (╬╝ : Measure Рёц_[2]) [╬╝.IsAddHaarMeasure] [IsProbabilityMeasure ╬╝] :
    MeasurePreserving TРѓѓ ╬╝ ╬╝ :=
  (TРѓѓ_stronglyMixing ╬╝).1

/-- `TРѓѓ` is **ergodic** on `РёцРѓѓ` for the 2-adic measure: it is strongly mixing
(`TРѓѓ_stronglyMixing`), hence ergodic by `StronglyMixing.ergodic`. (Genuinely derived, not assumed.) -/
@[category research solved, AMS 37 28, ref "BL96" "Lag85", group "bl_2adic_dynamics"]
theorem TРѓѓ_ergodic [MeasurableSpace Рёц_[2]] [BorelSpace Рёц_[2]]
    (╬╝ : Measure Рёц_[2]) [╬╝.IsAddHaarMeasure] [IsProbabilityMeasure ╬╝] :
    Ergodic TРѓѓ ╬╝ :=
  (TРѓѓ_stronglyMixing ╬╝).ergodic

